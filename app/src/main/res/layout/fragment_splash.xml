<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pokemon_default_bg"
    tools:context=".ui.splash.SplashFragment">

    <ImageView
        android:layout_width="@dimen/image_100"
        android:layout_height="@dimen/image_100"
        android:background="@drawable/pokeball"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="@dimen/padding_10"
        app:layout_constraintBottom_toTopOf="@id/splash_screen_app_name"/>

    <TextView
        android:id="@+id/splash_screen_app_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        style="@style/pokemon_title"
        android:text="@string/pokedex_splash"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/splash_screen_app_desc"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        style="@style/text_16_white"
        android:text="@string/gotta_know_em_all"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/splash_screen_app_name"/>

</androidx.constraintlayout.widget.ConstraintLayout>